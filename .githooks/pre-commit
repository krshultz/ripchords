#!/usr/bin/env bash
# ripchords pre-commit hook: run the same checks CI runs, before a commit lands.
# Enable once with:  make hooks   (sets core.hooksPath to .githooks)
set -euo pipefail

# Resolve golangci-lint from PATH, falling back to GOPATH/bin (where
# `go install` puts it).
golangci="$(command -v golangci-lint || true)"
if [ -z "$golangci" ]; then
  golangci="$(go env GOPATH)/bin/golangci-lint"
fi

echo "pre-commit: gofmt…"
unformatted="$(gofmt -l .)"
if [ -n "$unformatted" ]; then
  echo "These files need formatting (run: gofmt -w .):"
  echo "$unformatted"
  exit 1
fi

echo "pre-commit: go vet…"
go vet ./...

if [ -x "$golangci" ]; then
  echo "pre-commit: golangci-lint…"
  "$golangci" run ./...
else
  echo "pre-commit: golangci-lint not found — skipping (install with: make tools)"
fi

echo "pre-commit: go test…"
go test ./...

echo "pre-commit: all checks passed."
